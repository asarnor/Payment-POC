# Copy this file to .env and fill in values for local development
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_poc

# Prisma connection string - update credentials to match POSTGRES_USER and POSTGRES_PASSWORD above
# Scheme: postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@<host>:<port>/<POSTGRES_DB>
DATABASE_URL=postgresql://payment:payment@localhost:5432/payment_poc

NODE_ENV=development
PORT=3000

# API key for auth middleware (generate a strong random value for production)
API_KEY=dev-secret-key-change-in-production
