# Copy this file to .env and fill in values for local development
POSTGRES_USER=payment
POSTGRES_PASSWORD=payment
POSTGRES_DB=payment_poc

# Prisma connection string
# For local docker-compose, set to: postgresql://<user>:<pass>@localhost:5432/payment_poc
DATABASE_URL=postgresql://<user>:<pass>@localhost:5432/payment_poc

NODE_ENV=development
PORT=3000

# API key for auth middleware (generate a strong random value for production)
API_KEY=dev-secret-key-change-in-production
